@model IEnumerable<SV22T1020103.Models.Catalog.Product>
@using System.Globalization
@{
    ViewData["Title"] = "Cửa hàng";
    var culture = CultureInfo.GetCultureInfo("vi-VN");
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold m-0 text-uppercase" style="letter-spacing: 1px;">Sản phẩm</h3>
        <span class="text-muted small">Tìm thấy @(Model?.Count() ?? 0) mặt hàng</span>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body p-3">
            <form method="get" action="@Url.Action("Index", "Product")" id="filterForm" class="row g-2 align-items-end">

                <div class="col-md-3">
                    <label class="filter-label mb-1">TÊN MẶT HÀNG</label>
                    <input type="text" name="searchValue" class="form-control form-control-sm"
                           placeholder="Nhập tên sản phẩm..." value="@ViewBag.SearchValue" />
                </div>

                <div class="col-md-3">
                    <label class="filter-label mb-1">LOẠI HÀNG</label>
                    <select name="categoryId" class="form-select form-select-sm">
                        <option value="0">-- Tất cả loại hàng --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var c in (IEnumerable<SV22T1020103.Models.Catalog.Category>)ViewBag.Categories)
                            {
                                <option value="@c.CategoryID" selected="@(c.CategoryID == ViewBag.CurrentCategory)">
                                    @c.CategoryName
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="filter-label mb-1">KHOẢNG GIÁ</label>
                    <div class="input-group input-group-sm">
                        <input type="text" name="minPrice" class="form-control number-separator"
                               placeholder="Từ" value="@ViewBag.MinPrice" />
                        <span class="input-group-text">-</span>
                        <input type="text" name="maxPrice" class="form-control number-separator"
                               placeholder="Đến" value="@ViewBag.MaxPrice" />
                    </div>
                </div>

                <div class="col-md-2 d-flex gap-1">
                    <button type="submit" class="btn btn-dark btn-sm flex-grow-1">
                        <i class="fa fa-search"></i> TÌM KIẾM
                    </button>
                    <a href="@Url.Action("Index", "Product")" class="btn btn-outline-secondary btn-sm px-2">XÓA</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center py-5 border bg-white">
                <p class="text-muted m-0">Không tìm thấy sản phẩm nào khớp với yêu cầu.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="simple-product-card">
                        <div class="img-box">
                            <img src="~/images/@(string.IsNullOrEmpty(item.Photo) ? "no-image.png" : item.Photo)"
                                 onerror="this.src='/images/no-image.png'" />
                        </div>
                        <div class="content-box">
                            <h6 class="product-title">@item.ProductName</h6>
                            <div class="price-box">
                                <span class="product-price">@item.Price.ToString("N0", culture) đ</span>
                            </div>
                            <div class="action-buttons mt-3">
                                <a href="@Url.Action("Details", "Product", new { id = item.ProductID })"
                                   class="btn btn-sm btn-outline-dark flex-grow-1">Chi tiết</a>
                                <a href="@Url.Action("AddToCart", "Product", new { id = item.ProductID })"
                                   class="btn btn-sm btn-dark flex-grow-1">Thêm vào giỏ</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    /* CSS hỗ trợ giao diện mới */
    .filter-label {
        font-size: 0.7rem;
        font-weight: 700;
        color: #666;
        display: block;
    }

    .form-control-sm, .form-select-sm, .input-group-text {
        border-radius: 4px !important;
        font-size: 0.85rem;
    }

    /* Giữ nguyên các style card của bạn nhưng chỉnh lại tỉ lệ */
    .simple-product-card {
        border: 1px solid #eee;
        height: 100%;
        display: flex;
        flex-direction: column;
        background: #fff;
        transition: all 0.2s ease;
    }

        .simple-product-card:hover {
            border-color: #000;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05) !important;
        }

    .img-box {
        aspect-ratio: 1/1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px;
        background: #f9f9f9;
    }

        .img-box img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

    .content-box {
        padding: 12px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .product-title {
        font-weight: 600;
        font-size: 0.85rem;
        height: 2.5rem;
        overflow: hidden;
        margin-bottom: 5px;
    }

    .product-price {
        color: #d0021b;
        font-weight: 700;
        font-size: 1rem;
    }

    .btn-sm {
        font-size: 0.7rem;
        padding: 8px 4px;
    }
</style>

@* Giữ nguyên phần Script xử lý dấu chấm của bạn ở đây *@
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        function formatNumber(n) {
            return n.replace(/\D/g, "").replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }

        $('.number-separator').each(function() {
            var val = $(this).val();
            if(val) {
                var cleanVal = val.replace(/[\D\s\._\-]/g, "");
                $(this).val(formatNumber(cleanVal));
            }
        });

        $('.number-separator').on('input', function () {
            var $this = $(this);
            var input = $this.val().replace(/[\D\s\._\-]/g, "");
            $this.val(input === "" ? "" : formatNumber(input));
        });

        $('#filterForm').on('submit', function () {
            $('.number-separator').each(function () {
                var self = $(this);
                var pureNumber = self.val().replace(/\./g, "");
                $('<input>').attr({ type: 'hidden', name: self.attr('name'), value: pureNumber }).appendTo('#filterForm');
                self.removeAttr('name');
            });
        });
    });
</script>