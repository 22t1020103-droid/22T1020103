@model SV22T1020103.Shop.Models.Order

<div class="container mt-5 text-center">
    <div class="alert alert-success p-5 shadow-sm">
        <h1 class="display-4">🎉 Đặt hàng thành công!</h1>
        <p class="lead">Cảm ơn bạn, <strong>@Model.CustomerName</strong>. Đơn hàng của bạn đang được xử lý.</p>
        <hr>
        <div class="row justify-content-center">
            <div class="col-md-6 text-start">
                <p><strong>Mã đơn hàng:</strong> #@Model.OrderId</p>
                <p><strong>Số điện thoại:</strong> @Model.Phone</p>
                <p><strong>Địa chỉ:</strong> @Model.Address</p>
                <p><strong>Tổng tiền:</strong> <span class="text-danger fw-bold">@Model.TotalAmount.ToString("N0") đ</span></p>
                <p><strong>Trạng thái:</strong> <span class="badge bg-warning text-dark">@Model.Status</span></p>
            </div>
        </div>
        <div class="mt-4">
            <a href="@Url.Action("History", "Product")" class="btn btn-primary">Theo dõi đơn hàng của tôi</a>
            <a href="/" class="btn btn-outline-secondary">Về trang chủ</a>
        </div>
    </div>
</div>