<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shop Modern</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-color: #4361ee;
            --secondary-color: #f72585;
            --text-main: #1e293b;
            --text-muted: #64748b;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #ffffff;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            color: var(--text-main);
        }

        main {
            flex: 1;
        }

        /* Navbar cũ của bạn */
        .navbar {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.8) !important;
            border: 1px solid rgba(0,0,0,0.05) !important;
            overflow: visible !important;
        }

        .dropdown-menu {
            z-index: 999999 !important;
            border: none !important;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
            border-radius: 12px !important;
            margin-top: 10px !important;
        }

        /* --- THIẾT KẾ FOOTER MỚI: TINH TẾ & HIỆN ĐẠI --- */
        footer {
            background-color: #f8fafc; /* Màu xám cực nhẹ */
            padding: 60px 0 30px;
            margin-top: 80px;
            border-top: 1px solid #e2e8f0;
        }

        .footer-brand {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--text-main);
            letter-spacing: -0.5px;
            text-decoration: none;
        }

            .footer-brand i {
                color: var(--primary-color);
            }

        .footer-title {
            font-size: 0.95rem;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .footer-link {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.9rem;
            transition: 0.3s;
            display: block;
            margin-bottom: 12px;
        }

            .footer-link:hover {
                color: var(--primary-color);
                transform: translateX(5px);
            }

        .social-circle {
            width: 38px;
            height: 38px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            color: var(--text-muted);
            margin-right: 10px;
            transition: 0.3s;
            text-decoration: none;
        }

            .social-circle:hover {
                background: var(--primary-color);
                color: #ffffff;
                border-color: var(--primary-color);
                transform: translateY(-3px);
            }

        .contact-item {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

            .contact-item i {
                width: 30px;
                height: 30px;
                background: #eff6ff;
                color: var(--primary-color);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin-right: 12px;
            }

        .copyright {
            border-top: 1px solid #e2e8f0;
            margin-top: 40px;
            padding-top: 25px;
            font-size: 0.85rem;
            color: var(--text-muted);
        }
    </style>
</head>
<body>
    <header class="p-3" style="position: relative; z-index: 2000;">
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border rounded-pill px-4 mx-auto"
             style="max-width: 1200px;">
            <div class="container-fluid" style="overflow: visible !important;">
                <a class="navbar-brand fw-bolder" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-bolt-lightning me-2"></i>SHOP
                </a>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav mx-auto gap-2">
                        <li class="nav-item"><a class="nav-link px-3 fw-bold" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link px-3 fw-bold" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @* --- PHẦN NÚT GIỎ HÀNG CẬP NHẬT BADGE --- *@
                        @using Microsoft.AspNetCore.Http
                        @{
                            // Lấy số lượng từ Session (Bạn cần SetInt32("CartCount", value) trong Controller khi thêm hàng)
                            var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
                        }
                        <a class="btn btn-primary rounded-pill px-3 py-2 position-relative shadow-sm" asp-controller="Product" asp-action="ViewCart">
                            <i class="bi bi-cart3 fs-5 me-1"></i>
                            @if (cartCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      style="font-size: 0.7rem; border: 2px solid white;">
                                    @cartCount
                                </span>
                            }
                        </a>
                        @* ---------------------------------------- *@

                        @if (!string.IsNullOrEmpty(Context.Session.GetString("CustomerName")))
                        {
                            <div class="dropdown" style="position: relative; z-index: 3000;">
                                <button class="btn btn-outline-dark rounded-pill px-3 dropdown-toggle fw-bold"
                                        type="button" id="dropdownUser"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i> @Context.Session.GetString("CustomerName")
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="dropdownUser">
                                    <li><a class="dropdown-item py-2" href="/Account/Profile"><i class="bi bi-person-lines-fill me-2"></i> Hồ sơ cá nhân</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2 text-danger fw-bold logout-button" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        <div class="container mt-4">
            @RenderBody()
        </div>
    </main>

    <footer>
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <a href="#" class="footer-brand mb-3 d-inline-block">
                        <i class="fa-solid fa-bolt-lightning me-2"></i>SHOP MODERN
                    </a>
                    <p class="text-muted small lh-lg pe-lg-5 mb-4">
                        Mang đến những trải nghiệm mua sắm công nghệ tuyệt vời nhất. Chúng tôi cam kết chất lượng và sự tận tâm trên từng sản phẩm.
                    </p>
                    <div class="d-flex">
                        <a href="#" class="social-circle"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-circle"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-circle"><i class="bi bi-tiktok"></i></a>
                        <a href="#" class="social-circle"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>

                <div class="col-6 col-lg-2">
                    <h6 class="footer-title">Cửa hàng</h6>
                    <a href="/" class="footer-link">Trang chủ</a>
                    <a href="/Product" class="footer-link">Sản phẩm</a>
                    <a href="#" class="footer-link">Khuyến mãi</a>
                    <a href="#" class="footer-link">Tin tức</a>
                </div>

                <div class="col-6 col-lg-2">
                    <h6 class="footer-title">Hỗ trợ</h6>
                    <a href="#" class="footer-link">Bảo hành</a>
                    <a href="#" class="footer-link">Vận chuyển</a>
                    <a href="#" class="footer-link">Đổi trả</a>
                    <a href="#" class="footer-link">Liên hệ</a>
                </div>

                <div class="col-lg-4">
                    <h6 class="footer-title">Thông tin liên hệ</h6>
                    <div class="contact-item">
                        <i class="bi bi-geo-alt"></i>
                        <span>100 Lê Lợi, TP. Huế, Việt Nam</span>
                    </div>
                    <div class="contact-item">
                        <i class="bi bi-telephone"></i>
                        <span>0334 747 621</span>
                    </div>
                    <div class="contact-item">
                        <i class="bi bi-envelope"></i>
                        <span>support@shopmodern.vn</span>
                    </div>
                </div>
            </div>

            <div class="copyright text-center text-md-between d-md-flex justify-content-between align-items-center">
                <p class="mb-0">&copy; @DateTime.Now.Year Shop Modern. Thiết kế bởi SV22T1020103.</p>
                <div class="mt-2 mt-md-0">
                    <span class="me-3">Quy định</span>
                    <span>Bảo mật</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            $(document).on('click', '.logout-button', function (e) {
                e.preventDefault();
                const url = $(this).attr('href');
                if (url) window.location.replace(url);
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>