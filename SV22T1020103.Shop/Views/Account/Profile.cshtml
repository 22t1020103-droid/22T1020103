@model SV22T1020103.Models.Partner.Customer
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-white py-3">
        <h5 class="text-primary mb-0"><i class="fa-solid fa-user-gear me-2"></i> QUẢN LÝ TÀI KHOẢN</h5>
    </div>
    <div class="card-body p-4">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.Message != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fa-solid fa-check-circle me-2"></i> @ViewBag.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-controller="Account" asp-action="UpdateProfile" method="post">
            @* Luôn phải có ID ẩn để hệ thống biết cập nhật cho đúng người *@
            <input type="hidden" asp-for="CustomerID" />

            <h6 class="text-secondary fw-bold mb-3"><i class="fa-solid fa-info-circle me-2"></i> THÔNG TIN CÁ NHÂN</h6>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Tên hiển thị</label>
                    <input asp-for="CustomerName" class="form-control" required placeholder="Nhập họ tên của bạn" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Email (Tên đăng nhập)</label>
                    <input asp-for="Email" class="form-control bg-light" readonly />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Tỉnh/Thành phố</label>
                    <input asp-for="Province" class="form-control" placeholder="Ví dụ: Thừa Thiên Huế" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Địa chỉ</label>
                <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ chi tiết" />
            </div>

            <hr class="my-4" />

            <h6 class="text-secondary fw-bold mb-3"><i class="fa-solid fa-key me-2"></i> THAY ĐỔI MẬT KHẨU</h6>
            <div class="row mb-2">
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label fw-bold">Mật khẩu cũ</label>
                        <input name="oldPassword" type="password" class="form-control" placeholder="Mật khẩu hiện tại" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label fw-bold text-primary">Mật khẩu mới</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu mới" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label fw-bold text-primary">Xác nhận mật khẩu mới</label>
                        <input name="confirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <small class="text-muted fst-italic">
                    <i class="fa-solid fa-circle-info me-1"></i>
                    Để trống phần mật khẩu nếu bạn không muốn thay đổi. Nếu đổi, mật khẩu mới và xác nhận phải khớp nhau.
                </small>
            </div>

            <div class="d-flex justify-content-between pt-3 border-top mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-3">
                    <i class="fa-solid fa-house me-2"></i> Trang chủ
                </a>
                <button type="submit" class="btn btn-primary px-5 fw-bold">
                    <i class="fa-solid fa-floppy-disk me-2"></i> LƯU THAY ĐỔI
                </button>
            </div>
        </form>
    </div>
</div>