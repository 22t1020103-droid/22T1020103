@model ProductSearchInput
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}
@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Product/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    @* SỬA ĐỔI: Thêm sự kiện onchange để tự động tìm khi chọn loại hàng *@
                    <select class="form-select" asp-for="CategoryID"
                            asp-items="await SelectListHelper.Categories()"
                            onchange="paginationSearch(null, '#formSearch', 1)">
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    @* SỬA ĐỔI: Thêm sự kiện onchange *@
                    <select class="form-select" asp-for="SupplierID"
                            asp-items="await SelectListHelper.Suppliers()"
                            onchange="paginationSearch(null, '#formSearch', 1)">
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        @* SỬA ĐỔI: Thêm name để form gửi dữ liệu đúng *@
                        <input type="text"
                               asp-for="MinPrice"
                               class="form-control money-input"
                               placeholder="Từ" />
                        <span class="input-group-text">-</span>
                        <input type="text"
                               asp-for="MaxPrice"
                               class="form-control money-input"
                               placeholder="Đến" />
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="hidden" asp-for="PageSize" />
                        <input type="text"
                               class="form-control"
                               asp-for="SearchValue"
                               placeholder="Tên mặt hàng..." autofocus />
                        <button class="btn btn-info d-flex align-items-center" type="submit">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);

            // Tự động tìm kiếm khi người dùng ngừng gõ trong ô Giá hoặc Tên (delay 500ms)
            let timer;
            $('.form-control').on('input', function() {
                clearTimeout(timer);
                timer = setTimeout(function() {
                    paginationSearch(null, '#formSearch', 1);
                }, 500);
            });
        });
    </script>
}