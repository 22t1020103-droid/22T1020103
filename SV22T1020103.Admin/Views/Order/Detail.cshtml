@model SV22T1020103.Models.Sales.OrderViewInfo
@using SV22T1020103.Models.Sales

@{
    ViewBag.Title = "Chi tiết đơn hàng";
    var details = ViewBag.OrderDetails as List<OrderDetailViewInfo> ?? new List<OrderDetailViewInfo>();
    decimal totalAmount = details.Sum(x => x.Quantity * x.SalePrice);
}

@section PageToolBar {
    <div class="btn-group">
        @* 1.3.15: Chỉ hiển thị menu Xử lý nếu đơn hàng CHƯA kết thúc (Hoàn tất/Hủy/Từ chối) *@
        @if (Model.Status != OrderStatusEnum.Completed &&
            Model.Status != OrderStatusEnum.Cancelled &&
            Model.Status != OrderStatusEnum.Rejected)
        {
            <button type="button"
                    class="btn btn-primary dropdown-toggle"
                    data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i>
                Xử lý đơn hàng
            </button>
            <ul class="dropdown-menu">
                @* Trạng thái MỚI: Cho phép Duyệt, Từ chối, Hủy *@
                @if (Model.Status == OrderStatusEnum.New)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Accept/@Model.OrderID">Duyệt đơn hàng</a></li>
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/@Model.OrderID">Từ chối đơn hàng</a></li>
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
                }

                @* Đã DUYỆT: Cho phép Chuyển giao, Hủy *@
                @if (Model.Status == OrderStatusEnum.Accepted)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển giao hàng</a></li>
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
                }

                @* Đang GIAO HÀNG: Cho phép Hoàn tất, Hủy *@
                @if (Model.Status == OrderStatusEnum.Shipping)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Finish/@Model.OrderID">Hoàn tất đơn hàng</a></li>
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
                }
            </ul>
        }
    </div>

    @* Nút Xóa: Chỉ hiện khi đơn hàng ở trạng thái có thể xóa (Mới, Hủy hoặc Từ chối) *@
    @if (Model.Status == OrderStatusEnum.New ||
             Model.Status == OrderStatusEnum.Cancelled ||
             Model.Status == OrderStatusEnum.Rejected)
    {
        <a href="~/Order/Delete/@Model.OrderID"
           class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i>
            Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="alert @(Model.Status == OrderStatusEnum.Completed ? "alert-success" :
                            Model.Status == OrderStatusEnum.Cancelled || Model.Status == OrderStatusEnum.Rejected ? "alert-danger" :
                            "alert-info") d-flex align-items-center mb-3">
    <i class="bi bi-check-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @Model.Status.GetDescription()
        @if (Model.Status == OrderStatusEnum.New)
        {
            <text> lúc <b>@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</b></text>
        }
        else if (Model.Status == OrderStatusEnum.Accepted && Model.AcceptTime.HasValue)
        {
            <text> lúc <b>@Model.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm")</b></text>
        }
        else if (Model.Status == OrderStatusEnum.Shipping && Model.ShippedTime.HasValue)
        {
            <text> lúc <b>@Model.ShippedTime.Value.ToString("dd/MM/yyyy HH:mm")</b></text>
        }
        else if ((Model.Status == OrderStatusEnum.Completed ||
        Model.Status == OrderStatusEnum.Cancelled ||
        Model.Status == OrderStatusEnum.Rejected) && Model.FinishedTime.HasValue)
        {
            <text> lúc <b>@Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</b></text>
        }
    </div>
</div>

<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i>
            Thông tin đơn hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>

            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@Model.EmployeeName</div>

            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">
                @(Model.AcceptTime.HasValue? Model.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm") : "")
            </div>
        </div>
    </div>
</div>

<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Thông tin khách hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.CustomerName</div>

            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@Model.CustomerEmail</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-9">@Model.CustomerPhone</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.CustomerAddress</div>
        </div>
    </div>
</div>

<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-truck me-2"></i>
            Thông tin giao hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@Model.ShipperName</div>

            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.ShipperPhone</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.DeliveryProvince</div>
        </div>
    </div>
</div>

<div class="card card-secondary card-outline">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Danh sách mặt hàng
        </h5>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @if (details.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center">Đơn hàng chưa có mặt hàng nào</td>
                    </tr>
                }
                else
                {
                    int stt = 1;
                    foreach (var item in details)
                    {
                        <tr>
                            <td class="text-center">@stt</td>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Unit</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end">@((item.Quantity * item.SalePrice).ToString("N0"))</td>
                            <td class="text-end">
                                @* Chỉ cho sửa/xóa món hàng khi đơn chưa được Duyệt (Status == New) *@
                                @if (Model.Status == OrderStatusEnum.New)
                                {
                                    <a href="~/Order/EditCartItem/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-primary open-modal">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Order/DeleteCartItem/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-danger open-modal">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                        stt++;
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@totalAmount.ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $(document).on("click", ".open-modal", function (e) {
                e.preventDefault();
                var url = $(this).attr("href");

                if (url && url !== "#") {
                    $.get(url, function (data) {
                        $("#dialogModal .modal-content").html(data);
                        var myModal = new bootstrap.Modal(document.getElementById('dialogModal'));
                        myModal.show();
                    }).fail(function() {
                        alert("Không thể tải giao diện. Vui lòng kiểm tra lại!");
                    });
                }
            });
        });
    </script>
}